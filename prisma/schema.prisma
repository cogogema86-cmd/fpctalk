// FPCTalk DB schema
// Postgres on Supabase, accessed via Prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =====================================================
// 역할 (Role)
// 시스템 기본 역할 + 관리자가 추가하는 커스텀 역할
// =====================================================
model StaffRole {
  id           String   @id @default(cuid())
  // 시스템 식별자 — 시스템 6개는 PRINCIPAL/VICE/TEACHER/ASSISTANT/DRIVER/STAFF, 커스텀은 cuid
  code         String   @unique
  // 화면 표시명 (예: "원장", "교무부장")
  label        String
  // 직급 레벨 (0~3, 권한 차등에 활용 가능)
  defaultLevel Int      @default(0)
  // 관리 권한 (직원 추가/비번 초기화/역할 관리 등 가능)
  isAdmin      Boolean  @default(false)
  // 시스템 기본 역할 (수정/삭제 불가)
  isSystem     Boolean  @default(false)
  // 정렬 순서 (오름차순)
  sortOrder    Int      @default(100)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users User[]

  @@map("staff_roles")
}

// =====================================================
// 사용자
// =====================================================
model User {
  id     String @id @default(cuid())
  // Supabase Auth와 연결: auth.users.id를 외부키로 사용
  authId String @unique

  username     String  @unique
  name         String
  language     String  @default("ko")
  profileImage String?

  // 역할 (관계)
  roleId String
  role   StaffRole @relation(fields: [roleId], references: [id])
  // User-specific level (default는 role.defaultLevel에서 복사)
  level  Int       @default(0)

  // 직책/별명 (선택, 예: "수석강사")
  title String?

  annualLeaveTotal Int @default(15)
  annualLeaveUsed  Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 관계
  messages       Message[]
  chatMembers    ChatMember[]
  attendances    Attendance[]
  leaveRequests  LeaveRequest[]     @relation("LeaveRequester")
  leaveApprovals LeaveRequest[]     @relation("LeaveApprover")
  signRequests   SignatureRequest[] @relation("SignRequester")
  signs          SignatureRequest[] @relation("SignSigner")

  @@index([roleId])
}

// =====================================================
// 채팅
// =====================================================
model Chat {
  id        String   @id @default(cuid())
  type      ChatType @default(GROUP)
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members  ChatMember[]
  messages Message[]
}

enum ChatType {
  DM
  GROUP
}

model ChatMember {
  id     String @id @default(cuid())
  chatId String
  userId String

  joinedAt   DateTime  @default(now())
  lastReadAt DateTime?

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
  @@index([userId])
}

model Message {
  id       String      @id @default(cuid())
  chatId   String
  userId   String?
  type     MessageType @default(TEXT)
  content  String      @db.Text
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chat Chat  @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([chatId, createdAt])
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  AI
  SYSTEM
}

// =====================================================
// 근태
// =====================================================
model Attendance {
  id     String         @id @default(cuid())
  userId String
  type   AttendanceType
  at     DateTime       @default(now())
  note   String?
  latitude  Float?
  longitude Float?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, at])
}

enum AttendanceType {
  CHECK_IN
  CHECK_OUT
}

// =====================================================
// 연차/휴가
// =====================================================
model LeaveRequest {
  id          String      @id @default(cuid())
  requesterId String
  approverId  String?
  type        LeaveType
  startDate   DateTime
  endDate     DateTime
  reason      String?     @db.Text
  status      LeaveStatus @default(PENDING)
  decidedAt   DateTime?
  decidedNote String?     @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  requester User  @relation("LeaveRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  approver  User? @relation("LeaveApprover", fields: [approverId], references: [id], onDelete: SetNull)

  @@index([requesterId])
  @@index([status])
}

enum LeaveType {
  ANNUAL
  HALF_AM
  HALF_PM
  SICK
  OFFICIAL
  OTHER
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

// =====================================================
// 디지털 사인
// =====================================================
model Document {
  id          String   @id @default(cuid())
  uploaderId  String
  title       String
  description String?  @db.Text
  storagePath String
  mimeType    String   @default("application/pdf")
  pageCount   Int?

  createdAt DateTime @default(now())

  signatureRequests SignatureRequest[]

  @@index([uploaderId])
}

model SignatureRequest {
  id          String     @id @default(cuid())
  documentId  String
  requesterId String
  status      SignStatus @default(PENDING)
  pageNumber  Int        @default(1)
  positionX   Float?
  positionY   Float?

  // 내부 직원 사인자 (있으면 signer 사용)
  signerId String?

  // 외부 사인자 (학부모 등) — signerId 없을 때 사용
  externalName   String?
  externalEmail  String?
  externalPhone  String?
  accessToken    String?   @unique
  tokenExpiresAt DateTime?

  // 결과물
  signaturePath String?
  signedPdfPath String?
  signedAt      DateTime?
  signerIp      String?
  signerAgent   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  document  Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  requester User     @relation("SignRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  signer    User?    @relation("SignSigner", fields: [signerId], references: [id], onDelete: SetNull)

  @@index([signerId, status])
  @@index([requesterId])
  @@index([accessToken])
}

enum SignStatus {
  PENDING
  SIGNED
  REJECTED
  CANCELLED
}
