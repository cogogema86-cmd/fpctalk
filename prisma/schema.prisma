// FPCTalk DB schema
// Postgres on Supabase, accessed via Prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =====================================================
// 역할 (Role)
// 시스템 기본 역할 + 관리자가 추가하는 커스텀 역할
// =====================================================
model StaffRole {
  id           String   @id @default(cuid())
  // 시스템 식별자 — 시스템 6개는 PRINCIPAL/VICE/TEACHER/ASSISTANT/DRIVER/STAFF, 커스텀은 cuid
  code         String   @unique
  // 화면 표시명 (예: "원장", "교무부장")
  label        String
  // 직급 레벨 (0~3, 권한 차등에 활용 가능)
  defaultLevel Int      @default(0)
  // 관리 권한 (직원 추가/비번 초기화/역할 관리 등 가능)
  isAdmin      Boolean  @default(false)
  // 시스템 기본 역할 (수정/삭제 불가)
  isSystem     Boolean  @default(false)
  // 정렬 순서 (오름차순)
  sortOrder    Int      @default(100)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users User[]

  @@map("staff_roles")
}

// =====================================================
// 사용자
// =====================================================
model User {
  id     String @id @default(cuid())
  // Supabase Auth와 연결: auth.users.id를 외부키로 사용
  authId String @unique

  username     String  @unique
  name         String
  language     String  @default("ko")
  profileImage String?

  // 역할 (관계)
  roleId String
  role   StaffRole @relation(fields: [roleId], references: [id])
  // User-specific level (default는 role.defaultLevel에서 복사)
  level  Int       @default(0)

  // 직책/별명 (선택, 예: "수석강사")
  title String?

  // 입사일자 (계정 등록 시 입력) — 연차 발생 기준
  joinDate DateTime?

  // 연차 (반차 0.5일 단위 → Float)
  annualLeaveTotal Float @default(15)
  annualLeaveUsed  Float @default(0)

  // 계정 활성 여부 — false면 로그인 차단 + 직원/채팅 선택 목록에서 숨김 (퇴사자 처리, 복구 가능)
  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 관계
  messages           Message[]
  chatMembers        ChatMember[]
  attendances        Attendance[]
  leaveRequests      LeaveRequest[]     @relation("LeaveRequester")
  leaveApprovals     LeaveRequest[]     @relation("LeaveApprover")
  signRequests       SignatureRequest[] @relation("SignRequester")
  signs              SignatureRequest[] @relation("SignSigner")
  templates          DocumentTemplate[] @relation("TemplateUploader")
  pushSubscriptions  PushSubscription[]
  events             Event[]              @relation("EventCreator")
  eventAcks          EventAcknowledgement[]
  leaveAdjustments   LeaveAdjustment[]    @relation("LeaveAdjustmentTarget")
  leaveAdjustmentsBy LeaveAdjustment[]    @relation("LeaveAdjustmentAdmin")
  personalEvents     PersonalEvent[]

  @@index([roleId])
}

// =====================================================
// 연차 잔여 조정 감사 로그
// 관리자가 직원의 annualLeaveTotal / annualLeaveUsed 를 수동 변경할 때마다 기록.
// 운영 중 사이트 개설로 인한 보정, 이월, 정산, 육아휴직 등.
// =====================================================
model LeaveAdjustment {
  id        String   @id @default(cuid())
  userId    String   // 대상 직원
  adminId   String   // 변경한 관리자
  field     LeaveAdjustmentField // TOTAL or USED
  before    Float
  after     Float
  reason    String   @db.Text
  createdAt DateTime @default(now())

  user  User @relation("LeaveAdjustmentTarget", fields: [userId], references: [id], onDelete: Cascade)
  admin User @relation("LeaveAdjustmentAdmin", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([adminId])
}

enum LeaveAdjustmentField {
  TOTAL // annualLeaveTotal 변경 (한도)
  USED  // annualLeaveUsed 변경 (사용량)
}

// =====================================================
// 학원 행사 (관리자 채팅 메시지에서 AI가 추출 → 확인 후 등록)
// =====================================================
model Event {
  id          String   @id @default(cuid())
  title       String
  startDate   DateTime
  endDate     DateTime
  location    String?
  description String?

  createdById String
  createdBy   User   @relation("EventCreator", fields: [createdById], references: [id], onDelete: Cascade)

  source         EventSource @default(MANUAL)
  sourceMessageId String?    @unique // EVENT_PROPOSAL 메시지 (취소 시 정리)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  acknowledgements EventAcknowledgement[]

  @@index([startDate])
  @@index([createdById])
}

enum EventSource {
  MANUAL  // 직접 등록
  CHAT_AI // 채팅 메시지에서 AI 추출 → 확인
}

model EventAcknowledgement {
  id      String @id @default(cuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  ackedAt DateTime @default(now())

  @@unique([eventId, userId])
  @@index([userId])
}

// =====================================================
// 개인 일정 (PersonalEvent)
// 본인만 보는 비공개 일정. 학원 행사(Event)와 구분됨.
// AI 비서가 본인 컨텍스트로만 사용 — 그룹 채팅에는 절대 노출 X.
// =====================================================
model PersonalEvent {
  id      String @id @default(cuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title   String
  startAt DateTime
  endAt   DateTime?
  allDay  Boolean  @default(false)
  note    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, startAt])
}

// =====================================================
// Web Push 구독 (브라우저별 endpoint)
// =====================================================
model PushSubscription {
  id        String @id @default(cuid())
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  endpoint  String @unique
  p256dh    String // 암호화 키 (base64url)
  auth      String // 인증 secret (base64url)
  userAgent String?

  createdAt DateTime @default(now())
  lastUsed  DateTime?

  @@index([userId])
}

// =====================================================
// 채팅
// =====================================================
model Chat {
  id   String   @id @default(cuid())
  type ChatType @default(GROUP)
  name String?

  // 레벨 기반 자동 공개 채팅:
  // - null: DM 또는 명시적 멤버 그룹 (기존 동작)
  // - N (>=0): 사용자의 role.defaultLevel >= N 이면 자동으로 보임 (멤버 명시 불필요)
  levelRequired Int?

  // 레벨 채팅 생성자 (관리자) 추적용
  createdById String?

  // AI 자동 응답 모드:
  // - true이면 메시지가 질문형(? 끝나거나 의문사 포함)이고 @AI prefix가 아닐 때 AI가 자동 응답
  // - admin만 토글 가능
  aiAutoReply Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members  ChatMember[]
  messages Message[]

  @@index([levelRequired])
}

enum ChatType {
  DM
  GROUP
}

model ChatMember {
  id     String @id @default(cuid())
  chatId String
  userId String

  joinedAt   DateTime  @default(now())
  lastReadAt DateTime?

  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
  @@index([userId])
}

model Message {
  id       String      @id @default(cuid())
  chatId   String
  userId   String?
  type     MessageType @default(TEXT)
  content  String      @db.Text
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chat Chat  @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([chatId, createdAt])
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  AI
  SYSTEM
  EVENT_PROPOSAL // AI가 추출한 행사 등록 제안 (작성자에게 [확인]/[취소])
  ORDER          // AI 주문/수요조사 — open 상태면 채팅 하단 고정, 마감 후 일반 표시
}

// =====================================================
// 근태
// =====================================================
model Attendance {
  id     String         @id @default(cuid())
  userId String
  type   AttendanceType
  at     DateTime       @default(now())
  note   String?
  latitude  Float?
  longitude Float?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, at])
}

enum AttendanceType {
  CHECK_IN
  CHECK_OUT
}

// =====================================================
// 연차/휴가
// =====================================================
model LeaveRequest {
  id          String      @id @default(cuid())
  requesterId String
  approverId  String?
  type        LeaveType
  startDate   DateTime
  endDate     DateTime
  reason      String?     @db.Text
  status      LeaveStatus @default(PENDING)
  decidedAt   DateTime?
  decidedNote String?     @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  requester User  @relation("LeaveRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  approver  User? @relation("LeaveApprover", fields: [approverId], references: [id], onDelete: SetNull)

  @@index([requesterId])
  @@index([status])
}

enum LeaveType {
  ANNUAL
  HALF_AM
  HALF_PM
  SICK
  OFFICIAL
  OTHER
  ABSENT      // 결근 (무급, 연차 차감 안 함)
  TARDY       // 지각 (연차 차감 안 함)
  EARLY_LEAVE // 조퇴 (연차 차감 안 함)
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

// =====================================================
// 디지털 사인
// =====================================================
model Document {
  id          String   @id @default(cuid())
  uploaderId  String
  title       String
  description String?  @db.Text
  // 한국어(또는 단일 언어) 파일 — 기존 호환성 유지
  storagePath String
  mimeType    String   @default("application/pdf")
  pageCount   Int?

  // 영어 버전 (선택, 바이링구얼 문서용)
  storagePathEn String?
  mimeTypeEn    String?

  // 어떤 양식 템플릿에서 만들어졌는지 (옵션)
  templateId String?

  // 저장소 타입 — "supabase" (기존) 또는 "drive" (Google Drive)
  storageType String @default("supabase")

  createdAt DateTime @default(now())

  signatureRequests SignatureRequest[]
  template          DocumentTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([uploaderId])
  @@index([templateId])
}

// =====================================================
// 문서 양식 보관함 (관리자가 자주 쓰는 양식)
// =====================================================
model DocumentTemplate {
  id          String   @id @default(cuid())
  uploaderId  String
  name        String   // 예: "2026 연차휴가신청서"
  description String?  @db.Text

  // 한국어 버전 (필수)
  koPath     String
  koMime     String
  koFileName String

  // 영어 버전 (선택)
  enPath     String?
  enMime     String?
  enFileName String?

  // 저장소 타입
  storageType String @default("supabase")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  uploader User       @relation("TemplateUploader", fields: [uploaderId], references: [id], onDelete: Cascade)
  documents Document[]

  @@index([uploaderId])
  @@map("document_templates")
}

model SignatureRequest {
  id          String     @id @default(cuid())
  documentId  String
  requesterId String
  status      SignStatus @default(PENDING)
  pageNumber  Int        @default(1)
  positionX   Float?
  positionY   Float?

  // 내부 직원 사인자 (있으면 signer 사용)
  signerId String?

  // 외부 사인자 (학부모 등) — signerId 없을 때 사용
  externalName   String?
  externalEmail  String?
  externalPhone  String?
  accessToken    String?   @unique
  tokenExpiresAt DateTime?

  // 결과물
  signaturePath String?
  signedPdfPath String?
  signedAt      DateTime?
  signerIp      String?
  signerAgent   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  document  Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  requester User     @relation("SignRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  signer    User?    @relation("SignSigner", fields: [signerId], references: [id], onDelete: SetNull)

  @@index([signerId, status])
  @@index([requesterId])
  @@index([accessToken])
}

enum SignStatus {
  PENDING
  SIGNED
  REJECTED
  CANCELLED
}

// =====================================================
// 앱 설정 (key-value) — 관리자가 런타임에 바꾸는 값 (AI 모델명 등)
// 재배포 없이 즉시 반영. 값 없으면 코드가 env→기본값으로 폴백.
// =====================================================
model AppSetting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}
